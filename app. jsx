import { useState, useEffect } from "react";

const CSS = `
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap');
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --black: #0a0a0a; --white: #f5f4f0; --wgray: #b8b2a8; --mgray: #6b6560;
    --accent: #c8a97e; --adark: #9e7d54; --red: #c0392b;
    --border: rgba(184,178,168,0.25); --r: 2px;
  }
  .root { font-family:'DM Sans',sans-serif; background:var(--black); color:var(--white); min-height:100vh; -webkit-font-smoothing:antialiased; }
  .nav { position:fixed; top:0; left:0; right:0; display:flex; align-items:center; justify-content:space-between; padding:1rem 1.5rem; background:rgba(10,10,10,0.92); backdrop-filter:blur(10px); z-index:100; border-bottom:1px solid var(--border); }
  .logo { font-family:'Bebas Neue',sans-serif; font-size:1.4rem; color:var(--white); }
  .logo span { color:var(--accent); }
  .nbtn { font-size:0.62rem; letter-spacing:0.12em; text-transform:uppercase; padding:0.5rem 1rem; border:1px solid var(--border); background:transparent; color:var(--wgray); cursor:pointer; border-radius:var(--r); font-family:'DM Sans',sans-serif; }
  .ptnav { padding-top:56px; }
  .pgbar { position:fixed; top:0; left:0; right:0; height:2px; background:rgba(200,169,126,0.15); z-index:200; }
  .pgfill { height:100%; background:var(--accent); transition:width 0.3s; }

  .hero { position:relative; min-height:100vh; display:flex; flex-direction:column; justify-content:flex-end; padding:2rem 1.5rem 4rem; overflow:hidden; }
  .hero-bg { position:absolute; inset:0; pointer-events:none; background:radial-gradient(ellipse 80% 55% at 50% 0%, rgba(200,169,126,0.13) 0%, transparent 70%), repeating-linear-gradient(0deg,transparent,transparent 79px,rgba(184,178,168,0.03) 80px), repeating-linear-gradient(90deg,transparent,transparent 79px,rgba(184,178,168,0.03) 80px); }
  .hero-num { position:absolute; top:5rem; right:1.5rem; font-family:'Bebas Neue',sans-serif; font-size:5rem; color:rgba(200,169,126,0.07); user-select:none; pointer-events:none; }
  .hero-tag { font-size:0.6rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--accent); margin-bottom:1.25rem; display:flex; align-items:center; gap:0.75rem; }
  .hero-tag::before { content:''; display:inline-block; width:28px; height:1px; background:var(--accent); }
  .hero-ttl { font-family:'Bebas Neue',sans-serif; font-size:clamp(4rem,20vw,8rem); line-height:0.9; color:var(--white); }
  .hero-ttl span { color:var(--accent); }
  .hero-sub { font-size:0.82rem; color:var(--wgray); font-weight:300; line-height:1.65; max-width:280px; margin:0.75rem 0 2rem; }
  .hero-btn { display:flex; align-items:center; justify-content:center; gap:0.75rem; background:var(--accent); color:var(--black); font-size:0.75rem; font-weight:500; letter-spacing:0.12em; text-transform:uppercase; padding:1.2rem; border:none; cursor:pointer; border-radius:var(--r); font-family:'DM Sans',sans-serif; width:100%; position:relative; z-index:5; }

  .fwrap { background:var(--black); }
  .fhead { padding:2.5rem 1.5rem 1.75rem; border-bottom:1px solid var(--border); }
  .slbl { font-size:0.58rem; letter-spacing:0.2em; text-transform:uppercase; color:var(--accent); margin-bottom:0.6rem; display:flex; align-items:center; gap:0.4rem; }
  .slbl::before { content:'01'; color:var(--mgray); }
  .fttl { font-family:'Bebas Neue',sans-serif; font-size:2.4rem; line-height:1; color:var(--white); }
  .fttl em { font-style:italic; color:var(--accent); font-family:'DM Sans',sans-serif; font-size:1rem; }
  .fdesc { margin-top:0.6rem; font-size:0.78rem; color:var(--wgray); font-weight:300; line-height:1.7; }
  .fbody { padding:0 1.5rem 3rem; display:flex; flex-direction:column; }
  .field { padding:1.5rem 0; border-bottom:1px solid var(--border); }
  .flbl { font-size:0.64rem; letter-spacing:0.13em; text-transform:uppercase; color:var(--wgray); margin-bottom:0.85rem; display:flex; justify-content:space-between; }
  .opt { font-size:0.58rem; color:var(--mgray); text-transform:lowercase; font-style:italic; }
  .inp, .txa { width:100%; background:transparent; border:none; border-bottom:1px solid var(--border); color:var(--white); font-family:'DM Sans',sans-serif; font-size:0.95rem; font-weight:300; padding:0.55rem 0; outline:none; transition:border-color 0.2s; border-radius:0; }
  .inp:focus, .txa:focus { border-bottom-color:var(--accent); }
  .inp::placeholder, .txa::placeholder { color:var(--mgray); }
  .txa { resize:none; min-height:72px; line-height:1.6; }
  .row2 { display:grid; grid-template-columns:1fr 1fr; gap:1.25rem; }
  .sublbl { font-size:0.58rem; color:var(--mgray); letter-spacing:0.1em; text-transform:uppercase; margin-bottom:0.4rem; }
  .pills { display:flex; flex-wrap:wrap; gap:0.45rem; }
  .pill { padding:0.5rem 1rem; border:1px solid var(--border); color:var(--wgray); font-family:'DM Sans',sans-serif; font-size:0.75rem; cursor:pointer; background:transparent; border-radius:999px; }
  .pill.on { background:var(--accent); border-color:var(--accent); color:var(--black); font-weight:500; }
  .budgets { display:flex; flex-direction:column; gap:0.45rem; }
  .bud { display:flex; align-items:center; justify-content:space-between; padding:0.9rem 1.1rem; border:1px solid var(--border); cursor:pointer; border-radius:var(--r); }
  .bud.on { border-color:var(--accent); background:rgba(200,169,126,0.06); }
  .blbl { font-size:0.85rem; color:var(--white); font-weight:300; }
  .bdesc { font-size:0.62rem; color:var(--mgray); margin-top:0.12rem; }
  .radio { width:17px; height:17px; border:1px solid var(--border); border-radius:50%; display:flex; align-items:center; justify-content:center; }
  .bud.on .radio { border-color:var(--accent); }
  .dot { width:7px; height:7px; border-radius:50%; background:var(--accent); transform:scale(0); transition:transform 0.15s; }
  .bud.on .dot { transform:scale(1); }
  .subwrap { padding-top:2rem; }
  .subbtn { width:100%; padding:1.1rem; background:var(--white); color:var(--black); border:none; cursor:pointer; font-family:'Bebas Neue',sans-serif; font-size:1.3rem; letter-spacing:0.08em; display:flex; align-items:center; justify-content:center; gap:0.6rem; border-radius:var(--r); }
  .subbtn:disabled { opacity:0.35; cursor:not-allowed; }
  .subnote { margin-top:0.85rem; font-size:0.68rem; color:var(--mgray); text-align:center; line-height:1.65; }

  .success { min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:2rem; text-align:center; }
  .chk { width:60px; height:60px; border:1px solid var(--accent); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1.75rem; color:var(--accent); animation:popIn 0.4s cubic-bezier(0.34,1.56,0.64,1); }
  @keyframes popIn { from{transform:scale(0);opacity:0} to{transform:scale(1);opacity:1} }
  .sttl { font-family:'Bebas Neue',sans-serif; font-size:2.8rem; color:var(--white); }
  .ssub { font-size:0.82rem; color:var(--wgray); font-weight:300; line-height:1.7; max-width:270px; margin-top:0.5rem; }
  .snote { margin-top:1.25rem; font-size:0.78rem; color:var(--accent); }
  .back { margin-top:1.75rem; padding:0.6rem 1.5rem; border:1px solid var(--border); background:transparent; color:var(--wgray); font-family:'DM Sans',sans-serif; font-size:0.72rem; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; border-radius:var(--r); }

  .admhdr { padding:2rem 1.5rem 1.25rem; border-bottom:1px solid var(--border); }
  .admttl { font-family:'Bebas Neue',sans-serif; font-size:2.2rem; color:var(--white); }
  .admmeta { font-size:0.68rem; color:var(--mgray); letter-spacing:0.06em; margin-top:0.2rem; }
  .admbody { padding:1.25rem 1.5rem; display:flex; flex-direction:column; gap:0.85rem; }
  .empty { padding:2.5rem; text-align:center; color:var(--mgray); font-size:0.82rem; border:1px dashed var(--border); border-radius:var(--r); }
  .card { border:1px solid var(--border); border-radius:var(--r); overflow:hidden; }
  .card.open { border-color:var(--accent); }
  .chdr { padding:1.1rem 1.25rem; display:flex; align-items:center; justify-content:space-between; background:rgba(200,169,126,0.03); cursor:pointer; }
  .cname { font-family:'Bebas Neue',sans-serif; font-size:1.3rem; color:var(--white); }
  .cmeta { font-size:0.64rem; color:var(--mgray); margin-top:0.1rem; letter-spacing:0.05em; }
  .cbadge { font-size:0.58rem; letter-spacing:0.1em; text-transform:uppercase; padding:0.25rem 0.65rem; border-radius:999px; background:rgba(200,169,126,0.12); color:var(--accent); }
  .chev { color:var(--mgray); transition:transform 0.2s; }
  .card.open .chev { transform:rotate(180deg); }
  .cbody { padding:1.25rem; border-top:1px solid var(--border); display:grid; gap:0.85rem; }
  .dr { display:grid; grid-template-columns:85px 1fr; gap:0.4rem; }
  .dk { font-size:0.6rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--mgray); padding-top:0.1rem; }
  .dv { font-size:0.82rem; color:var(--wgray); font-weight:300; line-height:1.6; word-break:break-word; }
  .dv a { color:var(--accent); text-decoration:none; }
  .mpills { display:flex; flex-wrap:wrap; gap:0.3rem; }
  .mpill { font-size:0.65rem; padding:0.18rem 0.55rem; border:1px solid rgba(200,169,126,0.3); color:var(--accent); border-radius:999px; }
  .clrbtn { margin-top:0.75rem; padding:0.6rem 1.1rem; border:1px solid rgba(192,57,43,0.3); background:transparent; color:var(--red); font-size:0.66rem; letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; border-radius:var(--r); font-family:'DM Sans',sans-serif; }

  .gate { min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:2rem; }
  .glogo { font-family:'Bebas Neue',sans-serif; font-size:2.8rem; color:var(--white); text-align:center; }
  .glogo span { color:var(--accent); }
  .gsub { font-size:0.72rem; color:var(--mgray); margin:0.4rem 0 2rem; text-align:center; letter-spacing:0.06em; }
  .gbox { width:100%; max-width:300px; }
  .pinp { width:100%; padding:0.9rem; background:rgba(255,255,255,0.04); border:1px solid var(--border); color:var(--white); font-size:1rem; font-family:'DM Sans',sans-serif; text-align:center; letter-spacing:0.15em; outline:none; margin-bottom:0.65rem; border-radius:var(--r); }
  .pinp:focus { border-color:var(--accent); }
  .pbtn { width:100%; padding:0.9rem; background:var(--accent); border:none; color:var(--black); font-family:'Bebas Neue',sans-serif; font-size:1.15rem; letter-spacing:0.08em; cursor:pointer; border-radius:var(--r); }
  .perr { color:var(--red); font-size:0.72rem; text-align:center; margin-top:0.5rem; }
`;

const OCCASIONS = ["School","Hangout","Date","Social media photos","Other"];
const STYLES = ["Korean (clean look)","Streetwear","Minimal","Dark / Edgy","Cute"];
const BUDGETS = [{id:"200-300",l:"฿200 – ฿300",d:"Budget-friendly"},{id:"300-500",l:"฿300 – ฿500",d:"Mid range"},{id:"500+",l:"฿500+",d:"Premium"}];
const BODY = ["Slim","Average","Chubby"];
const GENDER = ["Male","Female","Prefer not to say"];
const PASS = "setsync2024";
const EMPTY = {nickname:"",gender:"",height:"",weight:"",bodyType:"",occasions:[],occasionOther:"",styles:[],budget:"",existingItems:"",refUrl:"",desiredOutcome:"",contact:""};

export default function App() {
  const [view, setView]     = useState("home");
  const [form, setForm]     = useState(EMPTY);
  const [subs, setSubs]     = useState([]);
  const [open, setOpen]     = useState(null);
  const [prog, setProg]     = useState(0);
  const [authed, setAuthed] = useState(false);
  const [pass, setPass]     = useState("");
  const [perr, setPerr]     = useState("");

  useEffect(() => { try { const s = localStorage.getItem("ss"); if(s) setSubs(JSON.parse(s)); } catch {} }, []);

  useEffect(() => {
    const f = [form.nickname,form.gender,form.height,form.weight,form.bodyType,form.occasions.length,form.styles.length,form.budget,form.desiredOutcome,form.contact];
    setProg(Math.round(f.filter(Boolean).length/f.length*100));
  }, [form]);

  const save = n => { try { localStorage.setItem("ss", JSON.stringify(n)); } catch {} };
  const tog = (k,v) => setForm(f => { const a=f[k]; return {...f,[k]:a.includes(v)?a.filter(x=>x!==v):[...a,v]}; });
  const go = v => { setView(v); window.scrollTo(0,0); };

  const submit = () => {
    if (!form.nickname || !form.gender || !form.contact) return;
    const n = [{...form,id:Date.now(),at:new Date().toISOString()},...subs];
    setSubs(n); save(n); go("success"); setForm(EMPTY);
  };

  const fmtDate = iso => new Date(iso).toLocaleDateString("en-GB",{day:"2-digit",month:"short",year:"numeric"});
  const canSub = form.nickname && form.gender && form.contact;

  if (view==="admin" && !authed) return (
    <div className="root"><style>{CSS}</style>
      <div className="gate">
        <div className="glogo">SET<span>SYNC</span></div>
        <div className="gsub">Owner access only</div>
        <div className="gbox">
          <input className="pinp" type="password" placeholder="Password" value={pass}
            onChange={e=>setPass(e.target.value)}
            onKeyDown={e=>{ if(e.key==="Enter"){ if(pass===PASS){setAuthed(true);setPerr("");}else setPerr("Wrong password"); }}}
          />
          <button className="pbtn" onClick={()=>{ if(pass===PASS){setAuthed(true);setPerr("");}else setPerr("Wrong password"); }}>Enter Dashboard</button>
          {perr && <div className="perr">{perr}</div>}
        </div>
        <button className="back" style={{marginTop:"1.75rem",padding:"0.6rem 1.5rem",border:"1px solid var(--border)",background:"transparent",color:"var(--wgray)",fontFamily:"DM Sans,sans-serif",fontSize:"0.72rem",letterSpacing:"0.1em",textTransform:"uppercase",cursor:"pointer",borderRadius:"var(--r)"}} onClick={()=>go("home")}>← Back</button>
      </div>
    </div>
  );

  if (view==="success") return (
    <div className="root"><style>{CSS}</style>
      <div className="success">
        <div className="chk">
          <svg width="26" height="26" fill="none" stroke="currentColor" strokeWidth="1.5" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
        </div>
        <div className="sttl">You're In</div>
        <div className="ssub">เราได้รับ style profile ของคุณแล้ว ทีมงานจะ curate outfit set และติดต่อกลับเร็วๆ นี้</div>
        <div className="snote">รอรับการติดต่อทาง LINE / IG ได้เลย ✦</div>
        <button className="back" onClick={()=>go("home")}>← กลับหน้าหลัก</button>
      </div>
    </div>
  );

  if (view==="admin") return (
    <div className="root"><style>{CSS}</style>
      <div className="nav">
        <div className="logo">SET<span>SYNC</span></div>
        <button className="nbtn" onClick={()=>{go("home");setAuthed(false);setPass("");}}>← ออก</button>
      </div>
      <div className="ptnav">
        <div className="admhdr">
          <div className="admttl">Submissions</div>
          <div className="admmeta">{subs.length} รายการ · Owner Dashboard</div>
        </div>
        <div className="admbody">
          {subs.length===0
            ? <div className="empty">ยังไม่มี submissions</div>
            : subs.map(s=>(
              <div key={s.id} className={`card${open===s.id?" open":""}`}>
                <div className="chdr" onClick={()=>setOpen(open===s.id?null:s.id)}>
                  <div>
                    <div className="cname">{s.nickname}</div>
                    <div className="cmeta">{fmtDate(s.at)} · {s.gender} · {s.budget?`฿${s.budget}`:"—"}</div>
                  </div>
                  <div style={{display:"flex",alignItems:"center",gap:"0.6rem"}}>
                    <span className="cbadge">New</span>
                    <svg className="chev" width="14" height="14" fill="none" stroke="currentColor" strokeWidth="2" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </div>
                </div>
                {open===s.id && (
                  <div className="cbody">
                    {[
                      ["Contact",s.contact],
                      ["Body",`${s.height||"?"}cm · ${s.weight||"?"}kg · ${s.bodyType||"?"}`],
                      ["Occasion",[...s.occasions,s.occasionOther].filter(Boolean).join(", ")],
                      ["Style",s.styles],
                      ["Budget",s.budget?`฿${s.budget}`:null],
                      ["Existing",s.existingItems],
                      ["Ref URL",s.refUrl?<a href={s.refUrl} target="_blank" rel="noopener noreferrer">{s.refUrl}</a>:null],
                      ["Goal",s.desiredOutcome],
                    ].map(([k,v])=>v&&(Array.isArray(v)?v.length:true)?(
                      <div className="dr" key={k}>
                        <div className="dk">{k}</div>
                        <div className="dv">{Array.isArray(v)?<div className="mpills">{v.map(x=><span className="mpill" key={x}>{x}</span>)}</div>:v}</div>
                      </div>
                    ):null)}
                  </div>
                )}
              </div>
            ))
          }
          {subs.length>0 && <button className="clrbtn" onClick={()=>{if(window.confirm("ลบข้อมูลทั้งหมด?")){setSubs([]);save([]);}}}>ลบข้อมูลทั้งหมด</button>}
        </div>
      </div>
    </div>
  );

  return (
    <div className="root">
      <style>{CSS}</style>
      <div className="pgbar"><div className="pgfill" style={{width:view==="form"?`${prog}%`:"0%"}}/></div>
      <div className="nav">
        <div className="logo">SET<span>SYNC</span></div>
        {view==="home"
          ? <button className="nbtn" onClick={()=>go("admin")}>Owner ↗</button>
          : <button className="nbtn" onClick={()=>go("home")}>← Back</button>
        }
      </div>

      {view==="home" && (
        <div className="hero">
          <div className="hero-bg"/>
          <div className="hero-num">01</div>
          <div className="hero-tag">Style Curation Service</div>
          <div className="hero-ttl">SET<br/><span>SYNC</span></div>
          <div className="hero-sub">We build your perfect outfit sets — based on your body, style, and vibe. Not a store. A service.</div>
          <button className="hero-btn" onClick={()=>go("form")}>
            GET MY OUTFIT SET &nbsp;→
          </button>
        </div>
      )}

      {view==="form" && (
        <div className="fwrap ptnav">
          <div className="fhead">
            <div className="slbl">Style Intake Form</div>
            <div className="fttl">Tell Us Your <em>Vibe.</em></div>
            <div className="fdesc">กรอกข้อมูลแล้วเราจะ curate outfit set ให้เลย ใช้เวลาแค่ ~3 นาที</div>
          </div>
          <div className="fbody">

            <div className="field">
              <div className="flbl">Nickname <span className="opt">required</span></div>
              <input className="inp" type="text" placeholder="ชื่อที่อยากให้เราเรียก?" value={form.nickname} onChange={e=>setForm(f=>({...f,nickname:e.target.value}))}/>
            </div>

            <div className="field">
              <div className="flbl">Gender</div>
              <div className="pills">
                {GENDER.map(g=><button key={g} className={`pill${form.gender===g?" on":""}`} onClick={()=>setForm(f=>({...f,gender:g}))}>{g}</button>)}
              </div>
            </div>

            <div className="field">
              <div className="flbl">Body Measurements <span className="opt">optional</span></div>
              <div className="row2">
                <div><div className="sublbl">Height (cm)</div><input className="inp" type="number" placeholder="เช่น 165" value={form.height} onChange={e=>setForm(f=>({...f,height:e.target.value}))}/></div>
                <div><div className="sublbl">Weight (kg)</div><input className="inp" type="number" placeholder="เช่น 55" value={form.weight} onChange={e=>setForm(f=>({...f,weight:e.target.value}))}/></div>
              </div>
            </div>

            <div className="field">
              <div className="flbl">Body Type</div>
              <div className="pills">
                {BODY.map(b=><button key={b} className={`pill${form.bodyType===b?" on":""}`} onClick={()=>setForm(f=>({...f,bodyType:b}))}>{b}</button>)}
              </div>
            </div>

            <div className="field">
              <div className="flbl">Occasion <span className="opt">เลือกได้หลายข้อ</span></div>
              <div className="pills">
                {OCCASIONS.map(o=><button key={o} className={`pill${form.occasions.includes(o)?" on":""}`} onClick={()=>tog("occasions",o)}>{o}</button>)}
              </div>
              {form.occasions.includes("Other") && (
                <div style={{marginTop:"0.75rem"}}>
                  <input className="inp" type="text" placeholder="ระบุโอกาสอื่น..." value={form.occasionOther} onChange={e=>setForm(f=>({...f,occasionOther:e.target.value}))}/>
                </div>
              )}
            </div>

            <div className="field">
              <div className="flbl">Style Preference <span className="opt">เลือกได้หลายข้อ</span></div>
              <div className="pills">
                {STYLES.map(s=><button key={s} className={`pill${form.styles.includes(s)?" on":""}`} onClick={()=>tog("styles",s)}>{s}</button>)}
              </div>
            </div>

            <div className="field">
              <div className="flbl">Budget per Set</div>
              <div className="budgets">
                {BUDGETS.map(b=>(
                  <div key={b.id} className={`bud${form.budget===b.id?" on":""}`} onClick={()=>setForm(f=>({...f,budget:b.id}))}>
                    <div><div className="blbl">{b.l}</div><div className="bdesc">{b.d}</div></div>
                    <div className="radio"><div className="dot"/></div>
                  </div>
                ))}
              </div>
            </div>

            <div className="field">
              <div className="flbl">ของที่มีอยู่แล้ว <span className="opt">optional</span></div>
              <textarea className="txa" placeholder="เช่น กางเกงดำ, รองเท้าผ้าใบขาว, hoodie oversized..." value={form.existingItems} onChange={e=>setForm(f=>({...f,existingItems:e.target.value}))}/>
            </div>

            <div className="field">
              <div className="flbl">Reference URL <span className="opt">optional</span></div>
              <input className="inp" type="url" placeholder="ลิงก์ Instagram หรือ Pinterest..." value={form.refUrl} onChange={e=>setForm(f=>({...f,refUrl:e.target.value}))}/>
            </div>

            <div className="field">
              <div className="flbl">อยากได้ลุคแบบไหน?</div>
              <textarea className="txa" placeholder={'เช่น "อยากดูดีขึ้น" หรือ "อยากได้วายเกาหลีใส่ไปโรงเรียน"'} value={form.desiredOutcome} onChange={e=>setForm(f=>({...f,desiredOutcome:e.target.value}))}/>
            </div>

            <div className="field">
              <div className="flbl">ช่องทางติดต่อ <span className="opt">required</span></div>
              <input className="inp" type="text" placeholder="LINE ID หรือ Instagram @username" value={form.contact} onChange={e=>setForm(f=>({...f,contact:e.target.value}))}/>
            </div>

            <div className="subwrap">
              <button className="subbtn" onClick={submit} disabled={!canSub}>
                GET MY OUTFIT SET →
              </button>
              <div className="subnote">
                เราจะ review และติดต่อกลับทาง LINE หรือ Instagram
                {!canSub && <><br/><span style={{color:"var(--accent)"}}>กรุณากรอก nickname, gender และช่องทางติดต่อ</span></>}
              </div>
            </div>

          </div>
        </div>
      )}
    </div>
  );
}
